# REST API credentials for one TS4500 library.
# Copy to a path referenced in lib_check.cfg (e.g. /etc/check_mk/credentials/4500RZ1.creds)
# and restrict permissions: chmod 600 <file>
#
# USER     - REST API user (Monitor role is sufficient)
# PASSWORD - REST API password (plain text, no shell escaping)

USER=monitor
PASSWORD=changeme
