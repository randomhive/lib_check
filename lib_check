def check_library(name):
    lib = load_json()
    status = lib.get("status", "unknown")
    licensed = int(lib.get("licensedCapacity") or 0)
    assigned = int(lib.get("assignedCartridges") or 0)
    total_cap = int(lib.get("totalCapacity") or 0)
    total_cart = int(lib.get("totalCartridges") or 0)
    cleaning = int(lib.get("cleaningCartridges") or 0)
    data_cart = int(lib.get("dataCartridges") or 0)
    firmware = lib.get("firmware", "?")
    lib_name = lib.get("name", name)
    cart_access = lib.get("cartridgeAccess", "unknown")

    util = 0.0
    if licensed > 0:
        util = round(assigned * 100.0 / licensed, 1)

    state = 0
    if status != "online":
        state = 2
    elif cart_access not in ("normal", None):
        state = max(state, 1)
    if licensed > 0 and util >= 98:
        state = max(state, 2)
    elif licensed > 0 and util >= 90:
        state = max(state, 1)

    perf = (
        f"licensed_capacity={licensed}|assigned_cartridges={assigned}"
        f"|total_capacity={total_cap}|total_cartridges={total_cart}"
        f"|cleaning_cartridges={cleaning}|data_cartridges={data_cart}"
        f"|capacity_util={util};90;98;0;100"
    )
    text = (
        f"Library {lib_name}: status={status}, firmware={firmware}, "
        f"cartridgeAccess={cart_access}, utilization={util}%"
    )
    cmk_line(state, "Library", perf, text)


ACCESSOR_FIELD_ORDER = (
    "state",
    "stateReferenceEvent",
    "driveAccess",
    "cartridgeAccess",
    "pivots",
    "barCodeScans",
    "velocityScalingXY",
