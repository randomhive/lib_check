then
  error CONFIGFILE "$CONFIGFILE" not readable
  exit 98
fi

LINECOUNT=`grep -v '^#' "$CONFIGFILE" | grep -c ':' || true`
debug "configured libraries in $CONFIGFILE: $LINECOUNT"

