def check_accessors(name):
    accessors = load_json_list()
    if not accessors:
        cmk_line(2, "Accessors", "-", "No accessors reported")
        return

    for acc in accessors:
        loc = acc.get("location") or "unknown"

        state = 0
        if "state" in acc:
            state = accessor_state(acc["state"])
        if acc.get("driveAccess") not in (None, "normal"):
            state = max(state, 1)
        if acc.get("cartridgeAccess") not in (None, "normal"):
            state = max(state, 1)

        svc = f"Accessor_{short_name(loc, 'accessor_')}"
        cmk_line(state, svc, "-", ", ".join(accessor_fields(acc)))


CLEANING_REMAINING_WARN = 100
CLEANING_REMAINING_CRIT = 50


def check_cleaning(name):
    cartridges = load_json_list()
    count = len(cartridges)
    total_remaining = 0
    bad_state = 0

    for cc in cartridges:
        total_remaining += int(cc.get("cleansRemaining") or 0)
        if cc.get("state", "unknown") != "normal":
            bad_state += 1

    state = 0
    if count == 0:
        state = 2
    elif total_remaining <= CLEANING_REMAINING_CRIT:
        state = 2
    elif total_remaining <= CLEANING_REMAINING_WARN or bad_state > 0:
        state = 1

    perf = (
        f"cleaning_count={count}|cleans_remaining_total={total_remaining}"
        f";{CLEANING_REMAINING_WARN};{CLEANING_REMAINING_CRIT};0"
    )
    text = (
        f"Cleaning cartridges: count={count}, total remaining cleans={total_remaining}, "
        f"bad_state={bad_state}"
    )
    cmk_line(state, "Cleaning", perf, text)


def tier_has_cartridge(value):
    if value is None:
        return False
    if isinstance(value, str) and not value.strip():
        return False
    return True


def slot_cartridge_count(slot):
    from_contents = 0
    contents = slot.get("contents")
    if isinstance(contents, list):
        from_contents = sum(1 for item in contents if tier_has_cartridge(item))
    from_field = 0
    try:
        from_field = int(slot.get("cartridges") or 0)
    except (TypeError, ValueError):
        pass
    return max(from_contents, from_field)


def slot_tier_count(slot):
    from_field = 0
    try:
        from_field = int(slot.get("tiers") or 0)
    except (TypeError, ValueError):
        pass
    contents = slot.get("contents")
    from_contents = len(contents) if isinstance(contents, list) else 0
    return max(from_field, from_contents)


def check_slots(name):
    slots = load_json_list()
    physical_slots = len(slots)
    tier_capacity = 0
    cartridges = 0
    physical_occupied = 0
    in_service = 0

    state = 0
    for slot in slots:
        slot_state = slot.get("state", "unknown")
        slot_carts = slot_cartridge_count(slot)
        tiers = slot_tier_count(slot)
        tier_capacity += tiers
        cartridges += slot_carts

        if slot_state == "inServiceMode":
            in_service += 1
            state = max(state, 1)
        elif slot_state != "normal":
            state = max(state, 1)

        if slot_carts > 0:
            physical_occupied += 1

    tier_empty = tier_capacity - cartridges
    util = 0.0
    if tier_capacity > 0:
        util = round(cartridges * 100.0 / tier_capacity, 1)

    perf = (
        f"slots_total={tier_capacity}|slots_occupied={cartridges}"
        f"|slots_empty={tier_empty}|slots_physical={physical_slots}"
        f"|slots_physical_occupied={physical_occupied}"
        f"|slots_in_service={in_service};0;1|cartridges_in_slots={cartridges}"
        f"|slot_util={util};85;95;0;100"
    )
    text = (
        f"Slots: cartridges={cartridges}, tier_capacity={tier_capacity}, "
        f"empty_tiers={tier_empty}, physical_slots={physical_slots}, "
        f"physical_occupied={physical_occupied}, in_service={in_service}, "
        f"utilization={util}%"
    )
    cmk_line(state, "Slots", perf, text)


def check_drives(name):
    drives = load_json_list()
    fc_ports = load_fc_ports_list()
    if not drives:
        cmk_line(2, "Drives", "-", "No drives reported")
        return

    for drv in drives:
        loc = drv.get("location") or "unknown"
        matched_ports = ports_for_drive(fc_ports, loc, drv.get("sn"))

        state = 0
        if "state" in drv:
            state = drive_state(drv["state"])
        if drv.get("accessible") not in (None, "normal"):
            state = max(state, 1)
        for port in matched_ports:
            if "state" in port:
                state = max(state, fc_port_state(port["state"]))

        text_parts = drive_fields(drv)
        fc_text = format_fc_ports(matched_ports)
        if fc_text:
            text_parts.append(fc_text)

        svc = f"Drive_{short_name(loc, 'drive_')}"
        cmk_line(state, svc, "-", ", ".join(text_parts))


def check_fc_ports_summary(name):
    ports = load_json_list()
    if not ports:
        cmk_line(0, "FCPorts", "fc_port_count=0", "No FC ports reported")
        return

    summary_state = 0
    port_count = len(ports)
    bad_ports = 0

    for port in ports:
        state = fc_port_state(port.get("state", "unknown"))
        summary_state = max(summary_state, state)
        if state > 0:
            bad_ports += 1

    cmk_line(
        summary_state,
        "FCPorts",
        f"fc_port_count={port_count}|fc_port_bad={bad_ports}",
        f"FC ports: total={port_count}, bad={bad_ports}",
    )


def check_events(name):
    events = load_json_list()
    warnings = []
    errors = []

    for ev in events:
        severity = ev.get("severity", "")
        if severity == "warning":
            warnings.append(ev)
        elif severity == "error":
            errors.append(ev)

    warn_count = len(warnings)
    err_count = len(errors)
    state = 0
    if err_count > 0:
        state = 2
    elif warn_count > 0:
        state = 1

    perf = f"events_warning={warn_count}|events_error={err_count}"
    details = []
    for ev in errors[:5]:
        details.append(
            f"#{ev.get('ID')} [error] {ev.get('type', '?')}: "
            f"{(ev.get('description') or '')[:100]}"
        )
    for ev in warnings[:5]:
        details.append(
            f"#{ev.get('ID')} [warning] {ev.get('type', '?')}: "
            f"{(ev.get('description') or '')[:100]}"
        )
    text = (
        f"Active (not silenced) events: {err_count} error(s), {warn_count} warning(s)"
    )
    if details:
        text = f"{text} | " + " | ".join(details)
    cmk_line(state, "Events", perf, text)


def check_ethernet_ports(name):
    ports = load_json_list()
    active_ports = [port for port in ports if ethernet_port_is_active(port)]
    if not active_ports:
        cmk_line(0, "EthernetPorts", "ethernet_port_count=0", "No active Ethernet ports")
        return

    summary_state = 0
    port_count = len(active_ports)
    bad_ports = 0

    for port in active_ports:
        loc = port.get("location", "unknown")
        state_name = port.get("state")
        if state_name:
            state = ethernet_port_state(state_name)
        else:
            state = 0

        summary_state = max(summary_state, state)
        if state > 0:
            bad_ports += 1

        mac = port.get("macAddress") or "-"
        ipv4 = port.get("ipv4Address") or "-"
        assignment = port.get("ipv4Assignment") or "?"
        gateway = port.get("ipv4Gateway") or "-"
        svc = f"EthernetPort_{short_name(loc, 'ethernetPort_')}"
        text = (
            f"mac={mac}, ipv4={ipv4}, ipv4Subnet={port.get('ipv4Subnet') or '-'}, "
            f"ipv4Gateway={gateway}, ipv4Assignment={assignment}"
        )
        if state_name:
            text = f"state={state_name}, {text}"
        cmk_line(state, svc, "-", text)

    cmk_line(
        summary_state,
        "EthernetPorts",
        f"ethernet_port_count={port_count}|ethernet_port_bad={bad_ports}",
        f"Ethernet ports: active={port_count}, bad={bad_ports}",
    )


def check_node_cards(name):
    cards = load_json_list()
    if not cards:
        cmk_line(2, "NodeCards", "-", "No node cards reported")
        return

    summary_state = 0
    card_count = len(cards)
    bad_cards = 0

    for card in cards:
        state_name = card.get("state", "unknown")
        state = node_card_state(state_name)
        summary_state = max(summary_state, state)
        if state > 0:
            bad_cards += 1

        card_type = card.get("type") or "?"
        loc = card.get("location") or "unknown"
        card_id = card.get("ID", "?")
        firmware = card.get("firmware") or "?"
        part_num = card.get("partNum") or "?"
        sn = card.get("sn") or "?"

        svc = node_card_service_name(card)
        text = (
            f"type={card_type}, location={loc}, state={state_name}, "
            f"id={card_id}, firmware={firmware}, partNum={part_num}, sn={sn}"
        )

        if card_type == "LCC":
            reporting = card.get("reportingLCC")
            primary = card.get("primaryLCC")
            last_restart = card.get("lastRestart")
            cf_vendor = card.get("cfVendor")
            if reporting is not None:
                text = f"{text}, reportingLCC={reporting}"
            if primary is not None:
                text = f"{text}, primaryLCC={primary}"
            if last_restart:
                text = f"{text}, lastRestart={last_restart}"
            if cf_vendor:
                text = f"{text}, cfVendor={cf_vendor}"

        cmk_line(state, svc, "-", text)

    cmk_line(
        summary_state,
        "NodeCards",
        f"node_card_count={card_count}|node_card_bad={bad_cards}",
        f"Node cards: total={card_count}, bad={bad_cards}",
    )


def magazine_occupied_slots(magazine):
    if not isinstance(magazine, dict) or "contentsVolser" not in magazine:
        return 0
    volsers = magazine.get("contentsVolser") or []
    return sum(1 for volser in volsers if volser is not None)


def io_station_fields(station):
    fields = []

    if "state" in station:
        fields.append(f"state={station['state']}")

    door = station.get("door")
    if isinstance(door, dict):
        if "opened" in door:
            fields.append(f"door_opened={door['opened']}")
        if "lastChanged" in door:
            fields.append(f"door_lastChanged={door['lastChanged']}")

    magazine = station.get("magazine")
    if isinstance(magazine, dict):
        if "mediaType" in magazine:
            fields.append(f"mediaType={magazine['mediaType']}")
        if "ioSlots" in magazine:
            fields.append(f"ioSlots={magazine['ioSlots']}")
        if "contentsVolser" in magazine:
            occupied = magazine_occupied_slots(magazine)
            fields.append(f"occupied={occupied}")

    return fields


def check_io_stations(name):
    stations = load_json_list()
    if not stations:
        cmk_line(0, "IOstation", "IOslots=0", "No I/O stations reported")
        return

    total_occupied = 0
    summary_state = 0

    for station in stations:
        loc = station.get("location") or "unknown"
        fields = io_station_fields(station)

        state = 0
        if "state" in station:
            state = io_station_state(station["state"])

        door = station.get("door")
        if isinstance(door, dict) and door.get("opened") == "yes":
            state = max(state, 1)

        magazine = station.get("magazine")
        if isinstance(magazine, dict):
            total_occupied += magazine_occupied_slots(magazine)

        summary_state = max(summary_state, state)
        svc = f"IOStation_{short_name(loc, 'ioStation_')}"
        cmk_line(state, svc, "-", ", ".join(fields))

    fill_state = 0
    if total_occupied >= IO_SLOTS_CRIT:
        fill_state = 2
    elif total_occupied >= IO_SLOTS_WARN:
        fill_state = 1

    fill_state = max(fill_state, summary_state)
    perf = f"IOslots={total_occupied};{IO_SLOTS_WARN};{IO_SLOTS_CRIT};0"
    cmk_line(
        fill_state,
        "IOstation",
        perf,
        f"I/O station occupied slots={total_occupied}",
    )


def check_unassigned_cartridges(name):
    cartridges = load_json_list()
    unassigned = []
    bad_state = 0

    for cart in cartridges:
        if cartridge_logical_library(cart) is not None:
            continue
        unassigned.append(cart)
        if cart.get("state", "unknown") != "normal":
            bad_state += 1

    count = len(unassigned)
    state = 0
    if count > 0:
        state = 1
    if bad_state > 0:
        state = max(state, 2)

    sample_volsers = []
    for cart in unassigned[:10]:
        volser = cart.get("volser") or cart.get("internalAddress") or "?"
        sample_volsers.append(str(volser))

    perf = f"unassigned_cartridges={count}|unassigned_bad_state={bad_state}"
    text = f"Unassigned data cartridges: count={count}, bad_state={bad_state}"
    if sample_volsers:
        text = f"{text}, examples={', '.join(sample_volsers)}"
    cmk_line(state, "UnassignedCartridges", perf, text)


def check_logical_libraries(name):
    libraries = load_json_list()
    if not libraries:
        cmk_line(0, "LogicalLibraries", "-", "No logical libraries reported")
        return

    for entry in libraries:
        ll_name = entry.get("name") or "unknown"
        cartridges = entry.get("cartridges")
        drives = entry.get("drives")
        virtual_slots = entry.get("virtualSlots")
        virtual_io_slots = entry.get("virtualIOSlots")
        media = entry.get("mediaType")
        safeguarded = entry.get("safeguardedProtection")
        encryption = entry.get("encryptionMethod")

        state = 0
        util = 0.0
        if (
            virtual_slots is not None
            and cartridges is not None
            and int(virtual_slots) > 0
        ):
            util = round(int(cartridges) * 100.0 / int(virtual_slots), 1)
            if util >= 98:
                state = 2
            elif util >= 90:
                state = 1

        perf_parts = []
        if cartridges is not None:
            perf_parts.append(f"cartridges={cartridges}")
        if virtual_slots is not None:
            perf_parts.append(f"virtual_slots={virtual_slots}")
        if drives is not None:
            perf_parts.append(f"drives={drives}")
        if virtual_slots and cartridges is not None and int(virtual_slots) > 0:
            perf_parts.append(f"slot_util={util};90;98;0;100")
        perf = "|".join(perf_parts) if perf_parts else "-"

        fields = []
        if cartridges is not None:
            fields.append(f"cartridges={cartridges}")
        if virtual_slots is not None:
            fields.append(f"virtualSlots={virtual_slots}")
        if virtual_io_slots is not None:
            fields.append(f"virtualIOSlots={virtual_io_slots}")
        if drives is not None:
            fields.append(f"drives={drives}")
        if media is not None:
            fields.append(f"mediaType={media}")
        if safeguarded is not None:
            fields.append(f"safeguardedProtection={safeguarded}")
        if encryption is not None:
            fields.append(f"encryptionMethod={encryption}")
        if virtual_slots and cartridges is not None and int(virtual_slots) > 0:
            fields.append(f"utilization={util}%")

        svc = f"LogicalLib_{sanitize_service_token(ll_name)}"
        text = f"Logical library {ll_name}: " + ", ".join(fields)
        cmk_line(state, svc, perf, text)


def main():
    check = sys.argv[1]
    name = sys.argv[2]

    if check == "library":
        check_library(name)
    elif check == "accessors":
        check_accessors(name)
    elif check == "cleaning":
        check_cleaning(name)
    elif check == "slots":
        check_slots(name)
    elif check == "drives":
        check_drives(name)
    elif check == "fcports_summary":
        check_fc_ports_summary(name)
    elif check == "events":
        check_events(name)
    elif check == "ethernet_ports":
        check_ethernet_ports(name)
    elif check == "io_stations":
        check_io_stations(name)
    elif check == "unassigned_cartridges":
        check_unassigned_cartridges(name)
    elif check == "logical_libraries":
        check_logical_libraries(name)
    elif check == "node_cards":
        check_node_cards(name)
    else:
        raise ValueError(f"unknown check type: {check}")


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:
        check = sys.argv[1] if len(sys.argv) > 1 else "unknown"
        label = CHECK_LABELS.get(check, check)
        cmk_line(2, label, "-", f"Check failed: {exc}")
        sys.exit(1)
PYEOF
}

response_preview()
{
  if [ -f "$1" ]
  then
    head -c 160 "$1" 2>/dev/null | tr '\n' ' '
  fi
}

run_check()
{
  # $1 = endpoint, $2 = check type, remaining args passed to python
  ENDPOINT="$1"
  CHECK_TYPE="$2"
  shift 2

  debug run_check endpoint "$ENDPOINT" type "$CHECK_TYPE"
  api_get "$ENDPOINT"

  _svc_label=`check_service_label "$CHECK_TYPE"`

  if [ "$API_CURL_RC" -ne 0 ]
  then
    emit_cmk "2" "$_svc_label" "-" \
      "curl failed for ${ENDPOINT} (exit ${API_CURL_RC})"
    rm -f "$API_JSON_FILE"
    return 1
  fi

  if [ "$API_HTTP_CODE" != "200" ]
  then
    _preview=`response_preview "$API_JSON_FILE"`
    emit_cmk "2" "$_svc_label" "-" \
      "HTTP ${API_HTTP_CODE} from ${ENDPOINT}: ${_preview}"
    rm -f "$API_JSON_FILE"
    return 1
  fi

  if [ ! -s "$API_JSON_FILE" ]
  then
    emit_cmk "2" "$_svc_label" "-" "Empty response from ${ENDPOINT}"
    rm -f "$API_JSON_FILE"
    return 1
  fi

  process_checks "$API_JSON_FILE" "$CHECK_TYPE" "$LIB_NAME" "$@"
  rm -f "$API_JSON_FILE"
}

run_check_drives()
{
  # fetch drives and FC ports; FC data is merged into per-drive checks
  DRIVES_FILE=""
  FC_FILE=""

  debug run_check_drives
  api_get "drives"
  if [ "$API_CURL_RC" -ne 0 ] || [ "$API_HTTP_CODE" != "200" ] || [ ! -s "$API_JSON_FILE" ]
  then
    _preview=`response_preview "$API_JSON_FILE"`
    if [ "$API_CURL_RC" -ne 0 ]
    then
      emit_cmk "2" "Drives" "-" "curl failed for drives (exit ${API_CURL_RC})"
    elif [ "$API_HTTP_CODE" != "200" ]
    then
      emit_cmk "2" "Drives" "-" "HTTP ${API_HTTP_CODE} from drives: ${_preview}"
    else
      emit_cmk "2" "Drives" "-" "Empty response from drives"
    fi
    rm -f "$API_JSON_FILE"
    return 1
  fi
  DRIVES_FILE="$API_JSON_FILE"

  api_get "fcPorts"
  if [ "$API_CURL_RC" -eq 0 ] && [ "$API_HTTP_CODE" = "200" ] && [ -s "$API_JSON_FILE" ]
  then
    FC_FILE="$API_JSON_FILE"
    LIB_CHECK_JSON_FILE_FC="$FC_FILE" process_checks "$DRIVES_FILE" drives "$LIB_NAME"
  else
    debug run_check_drives fcPorts unavailable using drives only
    LIB_CHECK_JSON_FILE_FC="" process_checks "$DRIVES_FILE" drives "$LIB_NAME"
  fi
  rm -f "$DRIVES_FILE" "$FC_FILE"
  LIB_CHECK_JSON_FILE_FC=""
}

run_check_cartridges()
{
  debug run_check_cartridges
  api_get "dataCartridges"
  if [ "$API_CURL_RC" -ne 0 ] || [ "$API_HTTP_CODE" != "200" ] || [ ! -s "$API_JSON_FILE" ]
  then
    _preview=`response_preview "$API_JSON_FILE"`
    if [ "$API_CURL_RC" -ne 0 ]
    then
      emit_cmk "2" "UnassignedCartridges" "-" \
        "curl failed for dataCartridges (exit ${API_CURL_RC})"
    elif [ "$API_HTTP_CODE" != "200" ]
    then
      emit_cmk "2" "UnassignedCartridges" "-" \
        "HTTP ${API_HTTP_CODE} from dataCartridges: ${_preview}"
    else
      emit_cmk "2" "UnassignedCartridges" "-" "Empty response from dataCartridges"
    fi
    rm -f "$API_JSON_FILE"
    return 1
  fi

  process_checks "$API_JSON_FILE" unassigned_cartridges "$LIB_NAME"
  rm -f "$API_JSON_FILE"
}

process_library()
{
  debug process_library "$LIB_NAME" fqdn "$LIB_FQDN" connect "$LIB_CONNECT_HOST"

  COOKIE_JAR="${TMPDIR}/lib_check.${RUNID}.${LIB_NAME}.cookies"
  API_BASE=""
  LIB_HOST=""

  if ! load_credentials "$CRED_FILE"
  then
    emit_piggyback_open
    _cred_path=`resolve_cred_file "$CRED_FILE"`
    emit_cmk "2" "Connection" "-" "Credentials file not readable: ${_cred_path}"
    emit_piggyback_close
    return 1
  fi

  emit_piggyback_open

  if ! api_connect_library
  then
    if [ -n "$LOGIN_ERR" ]
    then
      _login_msg="REST login failed (${LOGIN_ERR})"
    else
      _login_msg="REST login failed for ${LIB_CONNECT_HOST}"
    fi
    emit_cmk "2" "Connection" "-" "$_login_msg"
    emit_piggyback_close
    rm -f "$COOKIE_JAR"
    return 1
  fi

  run_check library library || true
  run_check accessors accessors || true
  run_check cleaningCartridges cleaning || true
  run_check slots slots || true
  run_check_drives || true
  run_check fcPorts fcports_summary || true
  run_check events events || true
  run_check ethernetPorts ethernet_ports || true
  run_check nodeCards node_cards || true
  run_check ioStations io_stations || true
  run_check_cartridges || true
  run_check logicalLibraries logical_libraries || true

  emit_piggyback_close

  api_logout
  rm -f "$COOKIE_JAR"
}


