#!/bin/sh

#Description: IBM TS4500 tape library monitoring via REST API (Check_MK local checks)
#Date       : 2026/06/08


UNAME_OS=`uname | tr '[:upper:]' '[:lower:]'`
case $UNAME_OS in
  linux)
          LOGDIR=/var/log
          ;;
  aix)
          LOGDIR=/var/adm
          ;;
  hp-ux)
          LOGDIR=/var/adm
          ;;
  darwin)
          LOGDIR=log
          ;;
      *)  echo "ERROR: architecture not recognized"
          echo
          exit 98
          ;;
esac

export SCRIPT_NAME=lib_check
export LOGFILE=${LOGDIR}/${SCRIPT_NAME}.log
export RUNDIR=`dirname "$0"`
export TMPDIR=/tmp
export CONFIGFILE=lib_check.cfg
export DEBUG=${DEBUG:=0}
export ECHO_BIN=/bin/echo
export RUNID=$$
export HOSTNAME=`hostname`

PYTHON3=""
for _py in python3 /usr/bin/python3; do
  if [ -x "$_py" ] 2>/dev/null || command -v "$_py" >/dev/null 2>&1; then
    PYTHON3="$_py"
    break
  fi
done

#
#### functions
error()
{
  $ECHO_BIN `date +'%Y-%m-%d %T'` "${SCRIPT_NAME}[${RUNID}] ERROR $1 $2 $3 $4 $5 $6 $7 $8 $9" >> $LOGFILE
  $ECHO_BIN "${0} ERROR $1 $2 $3 $4 $5 $6 $7 $8 $9"
  echo
  usage
}

emit()
{
  printf '%s\n' "$1"
}

emit_cmk()
{
  # $1 = state, $2 = service, $3 = perfdata, $4 = text
  emit "$1 $2 $3 $4"
}

emit_piggyback_open()
{
  emit "<<<<${LIB_FQDN}>>>>"
}

emit_piggyback_close()
{
  emit "<<<<>>>>"
}

check_service_label()
{
  # map internal check type to Check_MK service name (errors)
  case "$1" in
    library)          printf '%s' "Library" ;;
    accessors)        printf '%s' "Accessors" ;;
    cleaning)         printf '%s' "Cleaning" ;;
    slots)            printf '%s' "Slots" ;;
    drives)           printf '%s' "Drives" ;;
    fcports_summary)      printf '%s' "FCPorts" ;;
    events)               printf '%s' "Events" ;;
    ethernet_ports)       printf '%s' "EthernetPorts" ;;
    io_stations)          printf '%s' "IOstation" ;;
    unassigned_cartridges) printf '%s' "UnassignedCartridges" ;;
    logical_libraries)    printf '%s' "LogicalLibraries" ;;
    node_cards)           printf '%s' "NodeCards" ;;
    connection)           printf '%s' "Connection" ;;
    *)                printf '%s' "$1" ;;
  esac
}

warn()
{
  $ECHO_BIN `date +'%Y-%m-%d %T'` "${SCRIPT_NAME}[${RUNID}] WARN  $1 $2 $3 $4 $5 $6 $7 $8 $9" >> $LOGFILE
  $ECHO_BIN "${0} WARN  $1 $2 $3 $4 $5 $6 $7 $8 $9" >&2
}

info()
{
  $ECHO_BIN `date +'%Y-%m-%d %T'` "${SCRIPT_NAME}[${RUNID}] INFO  $1 $2 $3 $4 $5 $6 $7 $8 $9" >> $LOGFILE
  $ECHO_BIN "${0} INFO  $1 $2 $3 $4 $5 $6 $7 $8 $9" >&2
}

debug()
{
  if [ $DEBUG -eq 1 ]
  then
    $ECHO_BIN `date +'%Y-%m-%d %T'` "${SCRIPT_NAME}[${RUNID}] DEBUG $1 $2 $3 $4 $5 $6 $7 $8 $9" >> $LOGFILE
    $ECHO_BIN "${0} DEBUG $1 $2 $3 $4 $5 $6 $7 $8 $9" >&2
  fi
}

debug_curl()
{
  # print fully resolved curl command when DEBUG=1 (copy-paste ready, stderr only)
  if [ $DEBUG -eq 1 ]
  then
    _cmd=""
    for _arg in "$@"
    do
      if [ -z "$_cmd" ]
      then
        _cmd=`printf '%q' "$_arg"`
      else
        _cmd="${_cmd} `printf '%q' "$_arg"`"
      fi
    done
    $ECHO_BIN `date +'%Y-%m-%d %T'` "${SCRIPT_NAME}[${RUNID}] DEBUG curl ${_cmd}" >> $LOGFILE
    $ECHO_BIN "${0} DEBUG curl ${_cmd}" >&2
  fi
}

ssl_skip_enabled()
{
  _val=`printf '%s' "$1" | tr -d ' \t\r\n'`
  case "$_val" in
    1|yes|YES|true|on) return 0 ;;
    *) return 1 ;;
  esac
}

curl_lib()
{
  if ssl_skip_enabled "$SSL_SKIP"
  then
    curl -sSk "$@"
  else
    curl -sS "$@"
  fi
}

debug_curl_lib()
{
  if ssl_skip_enabled "$SSL_SKIP"
  then
    debug_curl curl -sSk "$@"
  else
    debug_curl curl -sS "$@"
  fi
}

usage()
{
  echo "usage $0"
  echo
  exit 99
}

parse_library_config()
{
  # NAME:FQDN:HOST:ALT_HOSTS:CREDENTIALS:SSL_SKIP
  _line=`printf '%s' "$1" | tr -d '\r'`
  LIB_NAME=""
  LIB_FQDN=""
  LIB_CONNECT_HOST=""
  LIB_ALT_HOSTS=""
  LIB_HOST=""
  CRED_FILE=""
  SSL_SKIP=0

  IFS=:
  set -- $_line
  LIB_NAME=${1:-}
  LIB_FQDN=${2:-}
  LIB_CONNECT_HOST=${3:-}
  LIB_ALT_HOSTS=${4:-}
  CRED_FILE=${5:-}
  SSL_SKIP=${6:-0}
  SSL_SKIP=`printf '%s' "$SSL_SKIP" | tr -d ' \t'`
  LIB_FQDN=`printf '%s' "$LIB_FQDN" | tr -d ' \t'`
  LIB_CONNECT_HOST=`printf '%s' "$LIB_CONNECT_HOST" | tr -d ' \t'`
  LIB_ALT_HOSTS=`printf '%s' "$LIB_ALT_HOSTS" | tr -d ' \t'`
}

resolve_cred_file()
{
  # relative paths are resolved against the script directory
  _cred="$1"
  case "$_cred" in
    /*) printf '%s' "$_cred" ;;
    *)  printf '%s' "${RUNDIR}/${_cred}" ;;
  esac
}

strip_cred_value()
{
  _val="$1"
  case "$_val" in
    \"*) _val=${_val#\"}; _val=${_val%\"} ;;
    \'*) _val=${_val#\'}; _val=${_val%\'} ;;
  esac
  printf '%s' "$_val"
}

load_credentials()
{
  # reads USER and PASSWORD from credentials file (no curl)
  CRED_FILE=`resolve_cred_file "$1"`

  if [ ! -r "$CRED_FILE" ]
  then
    warn credentials file "$CRED_FILE" not readable for "$LIB_NAME"
    return 1
  fi

  _raw_user=`grep '^USER=' "$CRED_FILE" | head -1 | cut -d= -f2-`
  _raw_password=`grep '^PASSWORD=' "$CRED_FILE" | head -1 | cut -d= -f2-`
  LIB_USER=`strip_cred_value "$_raw_user"`
  LIB_PASSWORD=`strip_cred_value "$_raw_password"`

  if [ -z "$LIB_USER" ] || [ -z "$LIB_PASSWORD" ]
  then
    warn credentials file "$CRED_FILE" missing USER or PASSWORD for "$LIB_NAME"
    return 1
  fi

  debug load_credentials file "$CRED_FILE" user "$LIB_USER"
  return 0
}

build_login_json()
{
  "$PYTHON3" -c 'import json,sys; print(json.dumps({"user": sys.argv[1], "password": sys.argv[2]}))' \
    "$LIB_USER" "$LIB_PASSWORD"
}

api_login()
{
  LOGIN_JSON=`build_login_json`
  if [ -z "$LOGIN_JSON" ]
  then
    LOGIN_ERR="failed to build login JSON"
    return 1
  fi

  CURL_ERR_FILE="${TMPDIR}/lib_check.${RUNID}.${LIB_NAME}.login.curlerr"
  debug api_login host "$LIB_HOST" user "$LIB_USER"
  debug_curl_lib \
    -c "$COOKIE_JAR" \
    -H 'Content-Type: application/json' \
    -X POST "${API_BASE}/login" \
    -d "$LOGIN_JSON"
  HTTP_CODE=`curl_lib -o /dev/null -w '%{http_code}' \
    -c "$COOKIE_JAR" \
    -H 'Content-Type: application/json' \
    -X POST "${API_BASE}/login" \
    -d "$LOGIN_JSON" 2>"$CURL_ERR_FILE"`
  CURL_RC=$?

  if [ $CURL_RC -ne 0 ]
  then
    LOGIN_ERR=`head -1 "$CURL_ERR_FILE" 2>/dev/null`
    if [ -z "$LOGIN_ERR" ]
    then
      LOGIN_ERR="curl exit ${CURL_RC}"
    fi
    rm -f "$CURL_ERR_FILE"
    return 1
  fi
  rm -f "$CURL_ERR_FILE"

  if [ "$HTTP_CODE" != "200" ] && [ "$HTTP_CODE" != "201" ]
  then
    LOGIN_ERR="HTTP ${HTTP_CODE}"
    return 1
  fi
  LOGIN_ERR=""
  return 0
}

api_connect_library()
{
  # try primary HOST then comma-separated ALT_HOSTS (other LCC management interfaces)
  _host_list="${LIB_CONNECT_HOST}"
  if [ -n "$LIB_ALT_HOSTS" ]
  then
    _host_list="${_host_list},${LIB_ALT_HOSTS}"
  fi

  _tried=""
  _old_ifs="$IFS"
  IFS=,
  for _try_host in $_host_list
  do
    _try_host=`printf '%s' "$_try_host" | tr -d ' \t'`
    if [ -z "$_try_host" ]
    then
      continue
    fi

    LIB_HOST="$_try_host"
    API_BASE="https://${LIB_HOST}/web/api/v1"
    rm -f "$COOKIE_JAR"
    debug api_connect trying "$LIB_HOST"

    if api_login
    then
      IFS="$_old_ifs"
      debug api_connect using "$LIB_HOST"
      return 0
    fi

    if [ -n "$LOGIN_ERR" ]
    then
      _entry="${_try_host} (${LOGIN_ERR})"
    else
      _entry="${_try_host}"
    fi
    if [ -z "$_tried" ]
    then
      _tried="$_entry"
    else
      _tried="${_tried}; $_entry"
    fi
  done
  IFS="$_old_ifs"

  LIB_HOST=""
  LOGIN_ERR="no reachable management host (${_tried})"
  return 1
}

api_logout()
{
  debug_curl_lib \
    -b "$COOKIE_JAR" -c "$COOKIE_JAR" \
    -H 'Content-Type: application/json' \
    -X POST "${API_BASE}/logout"
  curl_lib \
    -b "$COOKIE_JAR" -c "$COOKIE_JAR" \
    -H 'Content-Type: application/json' \
    -X POST "${API_BASE}/logout" >/dev/null 2>&1
}

api_get()
{
  # $1 = endpoint path without /v1/ prefix; sets API_JSON_FILE, API_HTTP_CODE, API_CURL_RC
  _endpoint="$1"
  API_JSON_FILE="${TMPDIR}/lib_check.${RUNID}.${LIB_NAME}.${_endpoint}.json"
  _err_file="${TMPDIR}/lib_check.${RUNID}.${_endpoint}.curlerr"

  debug_curl_lib \
    -b "$COOKIE_JAR" -c "$COOKIE_JAR" \
    -H 'Accept: application/json' \
    "${API_BASE}/${_endpoint}"
  API_HTTP_CODE=`curl_lib \
    -b "$COOKIE_JAR" -c "$COOKIE_JAR" \
    -H 'Accept: application/json' \
    -o "$API_JSON_FILE" -w '%{http_code}' \
    "${API_BASE}/${_endpoint}" 2>"$_err_file"`
  API_CURL_RC=$?

  _bytes=0
  if [ -f "$API_JSON_FILE" ]
  then
    _bytes=`wc -c < "$API_JSON_FILE" 2>/dev/null | tr -d ' '`
  fi
  debug api_get endpoint "$_endpoint" http "$API_HTTP_CODE" bytes "$_bytes" rc "$API_CURL_RC"
  if [ $DEBUG -eq 1 ] && [ -s "$API_JSON_FILE" ]
  then
    _preview=`head -c 120 "$API_JSON_FILE" 2>/dev/null | tr '\n' ' '`
    debug api_get preview "$_preview"
  fi
}

process_checks()
{
  # $1 = JSON response file, remaining args = check type and parameters
  LIB_CHECK_JSON_FILE="$1"
  export LIB_CHECK_JSON_FILE
  shift
  if [ -n "$LIB_CHECK_JSON_FILE_FC" ]
  then
    export LIB_CHECK_JSON_FILE_FC
  fi
  "$PYTHON3" - "$@" <<'PYEOF'
import json
import os
import sys

ACCESSOR_OK = {"onlineActive", "onlineStandby"}
ACCESSOR_WARN = {
    "scannerFailed", "gripper1Failed", "gripper2Failed",
    "calibrating", "noMovementAllowed",
}
ACCESSOR_CRIT = {
    "bothGrippersFailed", "noMotorPower", "unknown", "inServiceMode",
}

DRIVE_OK = {"online", "cleaning"}
DRIVE_WARN = {
    "initializing", "restarting", "resetRequired", "updating",
    "unreachable",
}
DRIVE_CRIT = {"unknown", "inServiceMode"}

FC_PORT_OK = {"communicationEstablished"}
FC_PORT_CRIT = {"failed", "unreachable"}

ETH_PORT_OK = {"online"}
ETH_PORT_CRIT = {"failed", "unreachable", "offline"}

NODE_CARD_OK = {"online"}
NODE_CARD_WARN = {"restarting", "unknown"}
NODE_CARD_CRIT = {"inServiceMode", "unreachable", "noEthernet", "noCAN"}

IO_STATION_OK = {"normal", "closedNoMagazine"}

IO_SLOTS_WARN = 200
IO_SLOTS_CRIT = 244

CHECK_LABELS = {
    "library": "Library",
    "accessors": "Accessors",
    "cleaning": "Cleaning",
    "slots": "Slots",
    "drives": "Drives",
    "fcports_summary": "FCPorts",
    "events": "Events",
    "ethernet_ports": "EthernetPorts",
    "io_stations": "IOstation",
    "unassigned_cartridges": "UnassignedCartridges",
    "logical_libraries": "LogicalLibraries",
    "node_cards": "NodeCards",
}


def cmk_line(state, service, perf="", text=""):
    perf_part = f" {perf}" if perf else ""
    text_part = f" {text}" if text else ""
    print(f"{state} {service}{perf_part}{text_part}")


def load_json_raw():
    path = os.environ.get("LIB_CHECK_JSON_FILE", "")
    if not path or not os.path.isfile(path):
        raise ValueError("missing API response file")
    with open(path, encoding="utf-8", errors="replace") as fh:
        raw = fh.read().strip()
    if not raw:
        raise ValueError("empty API response")
    return raw


def parse_json(raw):
    try:
        return json.loads(raw)
    except json.JSONDecodeError as exc:
        preview = raw[:160].replace("\n", " ")
        raise ValueError(f"invalid JSON ({exc}); response starts with: {preview!r}") from exc


def load_json():
    data = parse_json(load_json_raw())
    if isinstance(data, list) and len(data) == 1:
        return data[0]
    return data


def load_json_list():
    data = parse_json(load_json_raw())
    if isinstance(data, list):
        return data
    return [data]


def load_json_list_from(path):
    if not path or not os.path.isfile(path):
        return []
    with open(path, encoding="utf-8", errors="replace") as fh:
        raw = fh.read().strip()
    if not raw:
        return []
    data = parse_json(raw)
    if isinstance(data, list):
        return data
    return [data]


def load_fc_ports_list():
    return load_json_list_from(os.environ.get("LIB_CHECK_JSON_FILE_FC", ""))


def short_name(location, prefix):
    if location.startswith(prefix):
        return location[len(prefix):]
    return location


def accessor_state(state):
    if state in ACCESSOR_OK:
        return 0
    if state in ACCESSOR_WARN:
        return 1
    if state in ACCESSOR_CRIT:
        return 2
    return 1


def drive_state(state):
    if state in DRIVE_OK:
        return 0
    if state in DRIVE_WARN:
        return 1
    if state in DRIVE_CRIT:
        return 2
    return 1


def fc_port_state(state):
    if state in FC_PORT_OK:
        return 0
    if state in FC_PORT_CRIT or "fail" in state.lower():
        return 2
    return 1


def ethernet_port_state(state):
    if state in ETH_PORT_OK:
        return 0
    if state in ETH_PORT_CRIT or "fail" in state.lower():
        return 2
    return 1


def node_card_state(state):
    if state in NODE_CARD_OK:
        return 0
    if state in NODE_CARD_WARN:
        return 1
    if state in NODE_CARD_CRIT or "fail" in state.lower():
        return 2
    return 1


def node_card_service_name(card):
    card_type = card.get("type") or "unknown"
    loc = card.get("location") or "unknown"
    if loc.startswith("accessor_"):
        loc_short = short_name(loc, "accessor_")
    elif loc.startswith("frame_"):
        loc_short = short_name(loc, "frame_")
    else:
        loc_short = sanitize_service_token(loc)
    return f"NodeCard_{card_type}_{loc_short}"


def ethernet_ipv4_enabled(value):
    if value is None:
        return False
    if not isinstance(value, str):
        return False
    addr = value.strip()
    if not addr or addr.lower() == "disabled" or addr == "0":
        return False
    return "." in addr


def ethernet_port_is_active(port):
    return ethernet_ipv4_enabled(port.get("ipv4Address"))


def io_station_state(state):
    if state in IO_STATION_OK:
        return 0
    if state in ("inServiceMode",) or "fail" in state.lower():
        return 2
    return 1


def sanitize_service_token(value):
    token = (value or "unknown").strip()
    for ch in " /:\\|":
        token = token.replace(ch, "_")
    return token or "unknown"


def cartridge_logical_library(cart):
    ll = cart.get("logicalLibrary")
    if ll is None:
        return None
    if isinstance(ll, str) and ll.strip().lower() in ("", "null", "none"):
        return None
    return str(ll).strip()


def ports_for_drive(ports, drive_loc, drive_sn):
    matched = []
    seen = set()
    for port in ports:
        key = port.get("location")
        if key in seen:
            continue
        if port.get("driveLocation") == drive_loc or (
            drive_sn and port.get("driveSn") == drive_sn
        ):
            matched.append(port)
            if key:
                seen.add(key)
    return matched


FC_PORT_FIELD_ORDER = (
    "location",
    "portNumber",
    "state",
    "wwpn",
    "speedSetting",
    "speedActual",
    "topologySetting",
    "topologyActual",
    "loopID",
    "nPortID",
    "vendor",
    "sn",
    "pn",
    "manufactureDate",
)


def resource_fields(entry, field_order):
    fields = []
    for key in field_order:
        if key not in entry:
            continue
        value = entry[key]
        if value is None:
            continue
        fields.append(f"{key}={value}")
    return fields


def fc_port_fields(port):
    return resource_fields(port, FC_PORT_FIELD_ORDER)


def format_fc_ports(ports):
    parts = []
    for port in ports:
        fields = fc_port_fields(port)
        if fields:
            parts.append(", ".join(fields))
    return " | ".join(parts)


DRIVE_FIELD_ORDER = (
    "sn",
    "mediaType",
    "state",
    "operation",
    "accessible",
    "mtm",
    "barcode",
    "interface",
